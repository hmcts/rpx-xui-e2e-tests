TEST_SOLICITOR_ORGANISATION_ID=
# Organisation assignment strategy for dynamic provisioning:
# - auto: try fallback order (default)
# - external: call /refdata/external/v1/organisations/users/
# - internal: call /refdata/internal/v1/organisations/{orgId}/users/
PROFESSIONAL_USER_ASSIGNMENT_MODE=auto
PROFESSIONAL_USER_ASSIGNMENT_FALLBACK_ORDER=external,internal
# Dynamic solicitor role context (optional):
# - SOLICITOR_TEST_TYPE: provisioning|case-create|manage-org|invite-user|finance|full-access
# - SOLICITOR_JURISDICTION: prl|divorce|finrem|probate|ia|publiclaw|civil|employment
# - SOLICITOR_CASE_TYPE: free text; utility attempts jurisdiction inference from case type.
SOLICITOR_TEST_TYPE=
SOLICITOR_JURISDICTION=
SOLICITOR_CASE_TYPE=
# Credential output controls for created dynamic users
# default behavior: disabled (set to 1 to explicitly enable for debug/login capture)
# in CI, plaintext output still stays disabled unless ALLOW_CREDENTIAL_OUTPUT_IN_CI=1
PROFESSIONAL_USER_OUTPUT_CREATED_DATA=
ALLOW_CREDENTIAL_OUTPUT_IN_CI=
PROFESSIONAL_USER_EMAIL_DOMAIN=test.local
SOLICITOR_ROLE_PROFILE=
SKIP_CREATE_USER_TOKEN_SETUP=
ALLOW_CREATE_USER_TOKEN_FAILURE=
SKIP_S2S_TOKEN_SETUP=
ALLOW_S2S_TOKEN_FAILURE=

