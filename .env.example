# Playwright env template for rpx-xui-e2e-tests.
# Populate from Azure Key Vault with:
#   yarn env:populate:playwright:aat
#   yarn env:populate:playwright:demo
#
# Secret tagging convention:
# - add `e2e=<ENV_VAR_NAME>` to the Key Vault secret
# - `get-secrets` uses this template as the source of truth for what gets written to `.env`

# Core target settings
TEST_ENV=
TEST_URL=
BACKEND_BASE_URL=
MANAGE_CASES_BASE_URL=

# UI storage and session behaviour
PW_UI_STORAGE=
PW_UI_STORAGE_STRICT=
PW_UI_STORAGE_PATH=
PW_UI_STORAGE_TTL_MIN=15
PW_UI_LOGIN_TIMEOUT_MS=
PW_UI_MANUAL_TIMEOUT_MS=
PW_UI_MANUAL_USER=
PW_UI_MANUAL_USERS=
PW_UI_USER=
PW_UI_USERS=
PW_UI_IDLE_TIMEOUT_MS=
PW_UI_IDLE_QUIET_MS=
PW_UI_FAIL_ON_HTTP_ERRORS=
PW_UI_FAIL_ON_HTTP_4XX=
PW_UI_IDLE_ALLOWLIST=

# Reporting and diagnostics
PLAYWRIGHT_HTML_OUTPUT=
PLAYWRIGHT_REPORT_FOLDER=
PLAYWRIGHT_REPORT_TARGET=
PLAYWRIGHT_DEBUG_API=
PW_API_ENDPOINTS_OUTPUT=
PW_ODHIN_LINK_COVERAGE=
PW_ODHIN_OUTPUT=
PW_ODHIN_SKIP_API_ENDPOINTS=
PW_ODHIN_TARGET=
COVERAGE_SUMMARY_PATH=
COVERAGE_ROWS_PATH=
COVERAGE_TEXT_PATH=

