def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)
def archivePlaywrightDiagnostics = {
  steps.sh '''
    set +e
    out_dir="functional-output/tests/playwright-diagnostics/failure-data"
    mkdir -p "${out_dir}"
    if [ -d test-results ]; then
      find test-results -type f -name 'failure-data.json' | while read -r file; do
        rel="${file#test-results/}"
        safe_name=$(echo "${rel}" | tr '/ ' '__')
        cp "${file}" "${out_dir}/${safe_name}"
      done
    fi
  '''
  steps.archiveArtifacts(
    allowEmptyArchive: true,
    artifacts: 'functional-output/tests/**/odhin-report/**/*,functional-output/tests/playwright-diagnostics/failure-data/**/*,test-results/**/*,**/failure-data.json',
    excludes: 'test-results/.playwright-artifacts-*/**,**/.playwright-artifacts-*/**'
  )
}

withNightlyPipeline(type, product, component, 300) {
  loadVaultSecrets(secrets)
  def configuredWorkers = params.FUNCTIONAL_TESTS_WORKERS?.trim()
  env.TEST_URL = params.TEST_URL
  env.TEST_ENV = params.TEST_ENV
  env.FUNCTIONAL_TESTS_WORKERS = configuredWorkers ?: ''
  env.PLAYWRIGHT_WORKERS = configuredWorkers ?: ''
  env.PW_FLAKE_GATE = '1'
  env.PW_MAX_FLAKY_TESTS = params.PW_MAX_FLAKY_TESTS
  env.PW_MAX_FLAKY_RATE = params.PW_MAX_FLAKY_RATE
  env.GIT_BRANCH = env.BRANCH_NAME ?: (env.GIT_BRANCH ?: "local")
  enableSlackNotifications(channel)

  afterAlways('DependencyCheckNightly') {
    stage('Lint') {
      yarnBuilder.yarn('lint')
    }

    stage('Install Playwright Browsers') {
      yarnBuilder.yarn('pwinstall')
    }

    stage('Tests') {
      parallel(
        failFast: true,
        'API tests': {
          def apiOdhinEnv = [
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-api/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/api_functional/odhin-report',
            'PLAYWRIGHT_PROJECT=api',
            'PW_ODHIN_CONSOLE_TEST_OUTPUT=false',
            'PW_ODHIN_TEST_OUTPUT=only-on-failure',
            'PW_ODHIN_CAPTURE_STDIO=false',
            'PLAYWRIGHT_REPORTERS=list,odhin,junit',
            'PLAYWRIGHT_JUNIT_OUTPUT=functional-output/tests/api_functional/playwright-junit.xml',
            'PW_API_WORKERS='
          ]
          try {
            withEnv(apiOdhinEnv) {
              yarnBuilder.yarn('test:api:ci')
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            withEnv(apiOdhinEnv) {
              yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
            }
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/tests/api_functional/odhin-report",
              reportFiles          : 'xui-playwright-api.html',
              reportName           : 'API Odhín report'
            ])
            junit(testResults: "functional-output/tests/api_functional/playwright-junit.xml", allowEmptyResults: true)
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/api_functional/**'
            archivePlaywrightDiagnostics()
          }
        },
        'Playwright Integration Tests': {
          def integrationOdhinEnv = [
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-integration/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/playwright-integration/odhin-report',
            'PLAYWRIGHT_REPORTERS=list,odhin',
            'PW_ODHIN_CONSOLE_TEST_OUTPUT=false',
            'PW_ODHIN_TEST_OUTPUT=only-on-failure',
            'PW_ODHIN_CAPTURE_STDIO=false',
            'PW_UI_VIDEO=off',
            'ORG_USER_ASSIGNMENT_MODE=external',
            'ORG_USER_ASSIGNMENT_MODE_ORDER=external,internal',
            "PW_UI_WORKERS=${configuredWorkers ?: ''}",
            'PW_ODHIN_SKIP_API_ENDPOINTS=true',
            'PW_UI_USERS=COURT_ADMIN',
            'PW_UI_STORAGE_STRICT=1',
            'PW_UI_STORAGE=1',
            'PW_UI_STORAGE_TTL_MIN=15',
            'PW_UI_LOGIN_TIMEOUT_MS=120000',
            'PW_UI_IDLE_TIMEOUT_MS=60000',
            'PW_UI_IDLE_QUIET_MS=400',
            'PW_UI_FAIL_ON_HTTP_ERRORS=0',
            'PW_UI_FAIL_ON_HTTP_4XX=0'
          ]
          try {
            withEnv(integrationOdhinEnv) {
              yarnBuilder.yarn('test:playwright:integration')
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            withEnv(integrationOdhinEnv) {
              yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
            }
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/tests/playwright-integration/odhin-report",
              reportFiles          : 'xui-playwright-e2e.html',
              reportName           : 'Playwright Integration report'
            ])
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-integration/odhin-report/**'
            archivePlaywrightDiagnostics()
          }
        },
        'Playwright E2E Tests': {
          def uiOdhinEnv = [
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/playwright-e2e/odhin-report',
            'PLAYWRIGHT_REPORTERS=list,odhin',
            'PW_ODHIN_CONSOLE_TEST_OUTPUT=false',
            'PW_ODHIN_TEST_OUTPUT=only-on-failure',
            'PW_ODHIN_CAPTURE_STDIO=false',
            'PW_UI_VIDEO=off',
            'ORG_USER_ASSIGNMENT_MODE=external',
            'ORG_USER_ASSIGNMENT_MODE_ORDER=external,internal',
            "PW_UI_WORKERS=${configuredWorkers ?: ''}",
            'PW_ODHIN_SKIP_API_ENDPOINTS=true',
            'PW_UI_USERS=COURT_ADMIN',
            'PW_UI_STORAGE_STRICT=1',
            'PW_UI_STORAGE=1',
            'PW_UI_STORAGE_TTL_MIN=15',
            'PW_UI_LOGIN_TIMEOUT_MS=120000',
            'PW_UI_IDLE_TIMEOUT_MS=60000',
            'PW_UI_IDLE_QUIET_MS=400',
            'PW_UI_FAIL_ON_HTTP_ERRORS=0',
            'PW_UI_FAIL_ON_HTTP_4XX=0'
          ]
          try {
            withEnv(uiOdhinEnv) {
              yarnBuilder.yarn('test:playwrightE2E')
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
