def playwrightImage = "mcr.microsoft.com/playwright:v1.60.0-noble"
def playwrightDockerOptions = "--ipc=host"

def runInPlaywrightContainer = { Closure body ->
  withDocker(playwrightImage, playwrightDockerOptions) {
    body()
  }
}

def capJenkinsPlaywrightWorkers = { String configured ->
  def parsed = (configured ?: '4').trim()
  if (!parsed.isInteger()) {
    return '4'
  }
  return Math.min(4, Math.max(4, parsed.toInteger())).toString()
}

def hasCourtAdminUiCredentials = {
  env.COURT_ADMIN_USERNAME?.trim() && env.COURT_ADMIN_PASSWORD?.trim()
}

def resolveIntegrationProfileRuns = { String configuredRuns, String workersOverride, String shardOverride ->
  def requestedWorkers = workersOverride?.trim()
  if (requestedWorkers) {
    def requestedShard = shardOverride?.trim()
    return ["workers=${capJenkinsPlaywrightWorkers(requestedWorkers)}${requestedShard ? " shard=${requestedShard}" : ''}"]
  }
  def configured = configuredRuns?.trim()
  if (!configured) {
    configured = 'workers=4'
  }
  return configured
    .split(/[\r\n;]+/)
    .collect { it.trim() }
    .findAll { it }
}

def integrationProfileRunConfig = { String spec ->
  def workers = capJenkinsPlaywrightWorkers(params.FUNCTIONAL_TESTS_WORKERS)
  def shard = ''
  spec.split(/\s+/).each { token ->
    if (token.startsWith('workers=')) {
      workers = capJenkinsPlaywrightWorkers(token.replaceFirst('workers=', ''))
    }
    if (token.startsWith('shard=')) {
      shard = token.replaceFirst('shard=', '')
    }
  }
  def safeName = "workers-${workers}${shard ? "-shard-${shard}" : ''}".replaceAll(/[^A-Za-z0-9._-]/, '-')
  return [
    workers    : workers,
    shardArg   : shard ? " --shard=${shard}" : '',
    reportDir  : "functional-output/tests/playwright-integration/odhin-report/ci-${safeName}",
    displayName: "${workers} workers${shard ? ", shard ${shard}" : ''}"
  ]
}

def runPlaywrightShell = { String command ->
  sh(
    script: """#!/usr/bin/env bash
      set -euxo pipefail
      export PATH="\$HOME/.local/bin:\$PATH"
      corepack yarn --version
      ${command}
    """.stripIndent()
  )
}

def runDiagnostics = {
  stage('Diag: Playwright container evidence') {
    runInPlaywrightContainer {
      sh(
        script: '''#!/usr/bin/env bash
          set -euxo pipefail
          echo "=== diagnostic:start ==="
          echo "HOSTNAME=$(hostname)"
          echo "WHOAMI=$(whoami)"
          echo "PWD=$(pwd)"
          echo "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-<unset>}"
          echo "--- /etc/os-release ---"
          cat /etc/os-release || true
          echo "--- playwright image marker (/ms-playwright) ---"
          ls -la /ms-playwright || true
          echo "--- node + playwright package version ---"
          node -v
          node -e 'try { console.log(require("@playwright/test/package.json").version) } catch (e) { console.log("NO_PLAYWRIGHT_PACKAGE", e.message) }'
          echo "--- playwright CLI version ---"
          npx playwright --version || true
          echo "=== diagnostic:end ==="
        '''.stripIndent()
      )
    }
  }
}

def publishApiReports = {
