def runCnpPlaywrightStages = {
  def functionalWorkers = capJenkinsPlaywrightWorkers(params.FUNCTIONAL_TESTS_WORKERS)
  def integrationIncludeTags = removeTag(params.INTEGRATION_PW_INCLUDE_TAGS, '@nightly')
  def apiExcludedTags = effectiveTagOverride(params.API_PW_EXCLUDED_TAGS_OVERRIDE, '@svc-work-allocation')
  def integrationExcludedTags = effectiveTagOverride(params.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE, '@nightly')
  def quietConsoleEnv = [
    'TERM=dumb',
    'NO_COLOR=1',
    'FORCE_COLOR=0',
    'DOTENV_CONFIG_QUIET=true',
    'LOG_LEVEL=silent',
    'PW_API_MONITOR_CONSOLE=false',
    'PW_WA_SETUP_CONSOLE=false',
    'PW_ODHIN_CONSOLE_LOG=false',
    'PW_ODHIN_CONSOLE_ERROR=false',
    'PW_ODHIN_CONSOLE_TEST_OUTPUT=false',
    'PW_ODHIN_PROFILE=false',
    'PW_FLAKE_GATE_SUMMARY=compact',
    'PLAYWRIGHT_LOG_TAG_FILTERS=false'
  ]

  runDiagnostics()

  parallel(
    'API tests': {
      stage('API tests') {
        def apiEnv = quietConsoleEnv + [
          "FUNCTIONAL_TESTS_WORKERS=${functionalWorkers}",
          "PLAYWRIGHT_WORKERS=${functionalWorkers}",
          "API_PW_INCLUDE_TAGS=${params.API_PW_INCLUDE_TAGS}",
          "API_PW_EXCLUDED_TAGS_OVERRIDE=${apiExcludedTags}",
          "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
          'PLAYWRIGHT_REPORTERS=ci-brief,odhin,junit',
          'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-api/odhin-report',
          'PW_ODHIN_TARGET=functional-output/tests/api_functional/odhin-report',
          'PLAYWRIGHT_SKIP_INSTALL=true'
        ]
        try {
          runInPlaywrightContainer {
            withEnv(apiEnv) {
              runPlaywrightShell("corepack yarn test:api:ci:raw -- --workers=${functionalWorkers}")
            }
          }
        } catch (Exception e) {
          unstable(message: "${STAGE_NAME} is unstable: " + e.toString())
        } finally {
          publishApiReports()
        }
      }
    },
    'Integration tests': {
      stage('Integration tests') {
        resolveIntegrationProfileRuns(
          params.INTEGRATION_PW_PROFILE_RUNS ?: '',
          params.INTEGRATION_PW_WORKERS ?: '',
          params.INTEGRATION_PW_SHARD ?: ''
        ).each { spec ->
          def runConfig = integrationProfileRunConfig(spec)
          def integrationEnv = quietConsoleEnv + [
            "FUNCTIONAL_TESTS_WORKERS=${runConfig.workers}",
            "PLAYWRIGHT_WORKERS=${runConfig.workers}",
            "INTEGRATION_PW_INCLUDE_TAGS=${integrationIncludeTags}",
            "INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE=${integrationExcludedTags}",
            "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
            'PLAYWRIGHT_REPORTERS=ci-brief,odhin',
            'PW_UI_STORAGE=1',
            'PW_ODHIN_INDEX=playwright-odhin-integration.html',
            'PLAYWRIGHT_REPORT_INDEX_FILENAME=playwright-odhin-integration.html',
            "PLAYWRIGHT_REPORT_FOLDER=${runConfig.reportDir}",
            'PLAYWRIGHT_SKIP_INSTALL=true'
          ]
          try {
            runInPlaywrightContainer {
              withEnv(integrationEnv) {
                runPlaywrightShell("corepack yarn test:integration:raw -- --workers=${runConfig.workers}${runConfig.shardArg}")
              }
            }
          } catch (Exception e) {
            unstable(message: "${STAGE_NAME} ${runConfig.displayName} is unstable: " + e.toString())
          } finally {
            runInPlaywrightContainer {
              withEnv(integrationEnv) {
                runPlaywrightShell('node ./scripts/copy-odhin-report.cjs')
              }
            }
            publishIntegrationReports(runConfig)
          }
        }
      }
    },
    'UI tests': {
      stage('UI tests') {
        def uiEnv = quietConsoleEnv + [
          "FUNCTIONAL_TESTS_WORKERS=${functionalWorkers}",
          "PLAYWRIGHT_WORKERS=${functionalWorkers}",
          "PW_UI_WORKERS=${functionalWorkers}",
          "E2E_PW_INCLUDE_TAGS=${params.E2E_PW_INCLUDE_TAGS}",
          "E2E_PW_EXCLUDED_TAGS_OVERRIDE=${params.E2E_PW_EXCLUDED_TAGS_OVERRIDE}",
          "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
          'PLAYWRIGHT_REPORTERS=ci-brief,odhin',
          'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e/odhin-report',
          'PW_ODHIN_TARGET=functional-output/tests/playwright-e2e/odhin-report',
          'PW_ODHIN_SKIP_API_ENDPOINTS=true',
          'PW_UI_USERS=COURT_ADMIN',
          'PW_UI_STORAGE_STRICT=1',
          'PW_UI_STORAGE=1',
          'PW_UI_STORAGE_TTL_MIN=15',
          'PW_UI_LOGIN_TIMEOUT_MS=120000',
          'PW_UI_IDLE_TIMEOUT_MS=60000',
          'PW_UI_IDLE_QUIET_MS=400',
          'PW_UI_FAIL_ON_HTTP_ERRORS=0',
          'PW_UI_FAIL_ON_HTTP_4XX=0',
          'PLAYWRIGHT_SKIP_INSTALL=true'
        ]
        try {
          if (!hasCourtAdminUiCredentials()) {
            echo '[playwright-ui] Skipping UI tests: COURT_ADMIN_USERNAME/COURT_ADMIN_PASSWORD were not loaded from Key Vault.'
            runInPlaywrightContainer {
              withEnv(uiEnv) {
                runPlaywrightShell('node ./scripts/ensure-odhin-report.cjs')
              }
            }
          } else {
            runInPlaywrightContainer {
              withEnv(uiEnv) {
                runPlaywrightShell("corepack yarn test:ui:raw -- --workers=${functionalWorkers}")
              }
            }
          }
        } catch (Exception e) {
          unstable(message: "${STAGE_NAME} is unstable: " + e.toString())
        } finally {
          runInPlaywrightContainer {
            withEnv(uiEnv) {
              runPlaywrightShell('node ./scripts/copy-odhin-report.cjs')
            }
          }
          publishUiReports()
        }
      }
    },
    failFast: false
  )
}

withNightlyPipeline(type, product, component, 600) {
  env.BUILD_AGENT_TYPE = 'civil'
  loadVaultSecrets(secrets)
  env.TEST_URL = params.TEST_URL
  env.S2S_URL = params.S2S_URL
  env.TEST_ENV = params.TEST_ENV
  env.FUNCTIONAL_TESTS_WORKERS = capJenkinsPlaywrightWorkers(params.FUNCTIONAL_TESTS_WORKERS)
  env.PLAYWRIGHT_WORKERS = env.FUNCTIONAL_TESTS_WORKERS
  env.API_PW_INCLUDE_TAGS = params.API_PW_INCLUDE_TAGS
  env.API_PW_EXCLUDED_TAGS_OVERRIDE = effectiveTagOverride(params.API_PW_EXCLUDED_TAGS_OVERRIDE, '@svc-work-allocation')
  env.E2E_PW_INCLUDE_TAGS = params.E2E_PW_INCLUDE_TAGS
  env.E2E_PW_EXCLUDED_TAGS_OVERRIDE = params.E2E_PW_EXCLUDED_TAGS_OVERRIDE
  env.INTEGRATION_PW_INCLUDE_TAGS = params.INTEGRATION_PW_INCLUDE_TAGS
  env.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE = params.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE
  env.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES = params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES
  env.TERM = 'dumb'
  env.NO_COLOR = '1'
  env.FORCE_COLOR = '0'
  env.DOTENV_CONFIG_QUIET = 'true'
  env.LOG_LEVEL = 'silent'
  env.PW_API_MONITOR_CONSOLE = 'false'
  env.PW_WA_SETUP_CONSOLE = 'false'
  env.PW_ODHIN_CONSOLE_LOG = 'false'
  env.PW_ODHIN_CONSOLE_ERROR = 'false'
  env.PW_ODHIN_CONSOLE_TEST_OUTPUT = 'false'
  env.PW_ODHIN_PROFILE = 'false'
  env.PW_FLAKE_GATE_SUMMARY = 'compact'
  env.PLAYWRIGHT_LOG_TAG_FILTERS = 'false'
  enableSlackNotifications(channel)

  onPR() {
    afterAlways('DependencyCheckNightly') {
      runCnpPlaywrightStages()
    }
  }

  onMaster() {
    afterAlways('DependencyCheckNightly') {
      runCnpPlaywrightStages()
    }
  }
}
