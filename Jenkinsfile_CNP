static Map<String, Object> secret(String secretName, String envVariable) {
  [
    $class     : 'AzureKeyVaultSecret',
    secretType : 'Secret',
    name       : secretName,
    envVariable: envVariable
  ]
}

static String removeTag(String rawTags, String tagToRemove) {
  if (!rawTags?.trim()) {
    return ''
  }
  rawTags.split(/[,\s]+/)
    .findAll { tag -> tag && tag != tagToRemove }
    .join(',')
}

static String effectiveTagOverride(String rawTags, String fallbackTags) {
  def trimmed = rawTags?.trim()
  return trimmed ? trimmed : fallbackTags
}

static String effectiveIntegrationExcludedTags(String rawTags) {
  def tags = effectiveTagOverride(rawTags, '@nightly,@integration-bucket-6')
    .split(/[,\s]+/)
    .findAll { tag -> tag && tag != '@none' }
  if (!tags.contains('@integration-bucket-6')) {
    tags.add('@integration-bucket-6')
  }
  return tags.join(',')
}

static String effectiveIntegrationBuckets(String rawTags) {
  def defaultBuckets = '@integration-bucket-1,@integration-bucket-2,@integration-bucket-3,@integration-bucket-4,@integration-bucket-5'
  def trimmed = rawTags?.trim()
  return (!trimmed || trimmed == '@integration-bucket-1' || trimmed == '@integration-bucket-1,@integration-bucket-2' || trimmed == '@integration-bucket-1,@integration-bucket-2,@integration-bucket-3' || trimmed == '@integration-bucket-1,@integration-bucket-2,@integration-bucket-3,@integration-bucket-4') ? defaultBuckets : trimmed
}

static String effectiveIntegrationWorkers(String rawWorkers) {
  def trimmed = rawWorkers?.trim()
  return (!trimmed || trimmed == '2') ? '4' : trimmed
}

