def playwrightImage = "mcr.microsoft.com/playwright:v1.60.0-noble"
def playwrightDockerOptions = "--ipc=host"

def runInPlaywrightContainer = { Closure body ->
  withDocker(playwrightImage, playwrightDockerOptions) {
    body()
  }
}

def capJenkinsPlaywrightWorkers = { String configured ->
  def parsed = (configured ?: '4').trim()
  if (!parsed.isInteger()) {
    return '4'
  }
  return Math.min(4, Math.max(1, parsed.toInteger())).toString()
}

def buildOdhinEnvironmentLabel = { String workers ->
  def agentProfile = sh(
    returnStdout: true,
    script: '''#!/usr/bin/env bash
      set +e
      cpu_cores="$(getconf _NPROCESSORS_ONLN 2>/dev/null || nproc 2>/dev/null || true)"
      ram_gib="$(awk '/MemTotal/ { printf "%.1f", $2 / 1024 / 1024 }' /proc/meminfo 2>/dev/null || true)"
      profile=""
      if [ -n "$cpu_cores" ]; then
        profile="agent_cpu_cores=$cpu_cores"
      fi
      if [ -n "$ram_gib" ]; then
        if [ -n "$profile" ]; then
          profile="$profile | "
        fi
        profile="${profile}agent_ram_gib=$ram_gib"
      fi
      printf "%s" "$profile"
    '''.stripIndent()
  ).trim()
  def baseLabel = "${params.TEST_ENV} | ci | workers=${workers}"
  return agentProfile ? "${baseLabel} | ${agentProfile}" : baseLabel
}

def hasCourtAdminUiCredentials = {
  env.COURT_ADMIN_USERNAME?.trim() && env.COURT_ADMIN_PASSWORD?.trim()
}

def runPlaywrightShell = { String command ->
  sh(
    script: """#!/usr/bin/env bash
      set -euxo pipefail
      export PATH="\$HOME/.local/bin:\$PATH"
      corepack yarn --version
      ${command}
    """.stripIndent()
  )
}

def runDiagnostics = {
  stage('Diag: Playwright container evidence') {
    runInPlaywrightContainer {
      sh(
        script: '''#!/usr/bin/env bash
          set -euxo pipefail
          echo "=== diagnostic:start ==="
          echo "HOSTNAME=$(hostname)"
          echo "WHOAMI=$(whoami)"
          echo "PWD=$(pwd)"
          echo "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-<unset>}"
          echo "--- /etc/os-release ---"
          cat /etc/os-release || true
          echo "--- playwright image marker (/ms-playwright) ---"
          ls -la /ms-playwright || true
          echo "--- node + playwright package version ---"
          node -v
          node -e 'try { console.log(require("@playwright/test/package.json").version) } catch (e) { console.log("NO_PLAYWRIGHT_PACKAGE", e.message) }'
          echo "--- playwright CLI version ---"
          npx playwright --version || true
          echo "=== diagnostic:end ==="
        '''.stripIndent()
      )
    }
  }
}

