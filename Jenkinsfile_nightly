def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)
def playwrightImage = "mcr.microsoft.com/playwright:v1.60.0-noble"
def playwrightDockerOptions = "--ipc=host"
def playwrightLoadProfileReportFile = 'load-profile.html'
def ciLoadProfileDir = 'functional-output/tests/playwright-integration/load-profile/ci'
def ciLoadProfileEventsFile = 'functional-output/tests/playwright-integration/load-profile/ci-stage-events.jsonl'
def ciLoadProfilePublished = false

def runInPlaywrightContainer = { Closure body ->
  if (!params.PLAYWRIGHT_USE_DOCKER) {
    body()
    return
  }
  withDocker(playwrightImage, playwrightDockerOptions) {
    body()
  }
}

def runPlaywrightCommand = { String command ->
  if (!params.PLAYWRIGHT_USE_DOCKER) {
    yarnBuilder.yarn(command)
    return
  }
  def shellCommand = command.startsWith('node ') ? command : "corepack yarn ${command}"
  steps.sh """
    set +ex
    ${shellCommand}
  """
}

def recordPlaywrightContainerDiagnostics = {
  if (!params.PLAYWRIGHT_USE_DOCKER) {
    echo '[playwright-container] Docker execution disabled; Jenkins daily-agent diagnostics are limited in host mode.'
    return
  }
  runInPlaywrightContainer {
    steps.sh '''
      set +e
      echo "=== playwright-container:diagnostic:start ==="
      echo "HOSTNAME=$(hostname)"
      echo "WHOAMI=$(whoami)"
      echo "PWD=$(pwd)"
      echo "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-<unset>}"
      echo "--- /etc/os-release ---"
      cat /etc/os-release || true
      echo "--- /ms-playwright ---"
      ls -la /ms-playwright || true
      echo "--- node + playwright package version ---"
      node -v
      node -e 'try { console.log(require("@playwright/test/package.json").version) } catch (e) { console.log("NO_PLAYWRIGHT_PACKAGE", e.message) }'
      echo "--- playwright CLI version ---"
      npx playwright --version || true
      echo "=== playwright-container:diagnostic:end ==="
    '''
  }
}

def publishPlaywrightLoadProfile = { String reportDir, String reportName ->
  def safeReportName = reportName.replaceAll(/[^A-Za-z0-9._-]/, '-')
  def slimReportDir = "functional-output/tests/playwright-published-reports/load-profile/${safeReportName}"
  steps.sh """
    set +e
    node scripts/ensure-load-profile-report.cjs \\
      --report-dir '${reportDir}' \\
      --report-file '${playwrightLoadProfileReportFile}' \\
      --report-name '${reportName}'
  """
  steps.sh """
    set +e
    mkdir -p '${slimReportDir}'
    if [ -f '${reportDir}/${playwrightLoadProfileReportFile}' ]; then
      cp '${reportDir}/${playwrightLoadProfileReportFile}' '${slimReportDir}/${playwrightLoadProfileReportFile}'
    fi
  """
  archiveArtifacts allowEmptyArchive: true, artifacts: "${slimReportDir}/${playwrightLoadProfileReportFile}"
  publishHTML([
    allowMissing         : true,
    alwaysLinkToLastBuild: true,
    keepAll              : true,
    reportDir            : "${slimReportDir}/",
    reportFiles          : playwrightLoadProfileReportFile,
    reportName           : reportName
  ])
}

def startPlaywrightLoadProfile = { String reportDir, String label, String eventsFile ->
  steps.sh """
    set +e
    mkdir -p '${reportDir}'
    rm -f '${reportDir}/stop' '${reportDir}/monitor.pid'
    JENKINS_NODE_COOKIE=dontKillMe nohup node scripts/playwright-load-monitor.cjs \\
      --output-folder '${reportDir}' \\
      --label '${label}' \\
      --events-file '${eventsFile}' \\
      --stop-file '${reportDir}/stop' \\
      > '${reportDir}/monitor.log' 2>&1 &
    echo \$! > '${reportDir}/monitor.pid'
  """
}

def stopPlaywrightLoadProfile = { String reportDir ->
  steps.sh """
    set +e
    if [ -f '${reportDir}/monitor.pid' ]; then
      pid=\$(cat '${reportDir}/monitor.pid')
      touch '${reportDir}/stop'
      for i in \$(seq 1 30); do
        kill -0 "\${pid}" 2>/dev/null || break
        sleep 1
      done
      if kill -0 "\${pid}" 2>/dev/null; then
        kill -TERM "\${pid}" 2>/dev/null || true
        sleep 2
      fi
    fi
    if [ -f '${reportDir}/monitor.log' ]; then
      cat '${reportDir}/monitor.log'
    fi
  """
}

def recordPlaywrightLoadEvent = { String label, String eventType ->
  try {
    steps.sh "node scripts/playwright-load-event.cjs '${ciLoadProfileEventsFile}' '${label}' '${eventType}'"
  } catch (Exception e) {
    echo "[load-profile] failed to record ${label} ${eventType}: ${e.getMessage()}"
  }
}

def startCiLoadProfile = {
  startPlaywrightLoadProfile(ciLoadProfileDir, 'Jenkins nightly CI run', ciLoadProfileEventsFile)
  recordPlaywrightLoadEvent('Checkout', 'finish')
}

def publishCiLoadProfile = { String reportName ->
  if (ciLoadProfilePublished) {
    return
  }
  ciLoadProfilePublished = true
  stopPlaywrightLoadProfile(ciLoadProfileDir)
  publishPlaywrightLoadProfile(ciLoadProfileDir, reportName)
}

def capJenkinsPlaywrightWorkers = { String configured ->
  def parsed = (configured ?: '4').trim()
  if (!parsed.isInteger()) {
    return '8'
  }
  return Math.min(8, Math.max(1, parsed.toInteger())).toString()
}

def effectiveIntegrationBuckets = { String rawTags ->
  def defaultBuckets = '@integration-bucket-1,@integration-bucket-2,@integration-bucket-3,@integration-bucket-4'
  def trimmed = rawTags?.trim()
  return (!trimmed || trimmed == '@integration-bucket-1' || trimmed == '@integration-bucket-1,@integration-bucket-2' || trimmed == '@integration-bucket-1,@integration-bucket-2,@integration-bucket-3') ? defaultBuckets : trimmed
}

def hasCourtAdminUiCredentials = {
  env.COURT_ADMIN_USERNAME?.trim() && env.COURT_ADMIN_PASSWORD?.trim()
}

withNightlyPipeline(type, product, component, 400) {
  loadVaultSecrets(secrets)
  def functionalWorkers = capJenkinsPlaywrightWorkers(params.FUNCTIONAL_TESTS_WORKERS)
  def integrationWorkers = capJenkinsPlaywrightWorkers(params.INTEGRATION_PW_WORKERS ?: '2')
  def integrationIncludeTags = effectiveIntegrationBuckets(params.INTEGRATION_PW_INCLUDE_TAGS)
  def integrationExcludedTags = params.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE?.trim() ?: '@none'
  def integrationTagSlug = integrationIncludeTags.replaceAll(/[^A-Za-z0-9._-]+/, '-').replaceAll(/^-|-$/, '') ?: 'selected'
  def integrationReportDir = "functional-output/tests/playwright-integration-nightly/odhin-report/${integrationTagSlug}"
  env.TEST_URL = params.TEST_URL
  env.TEST_ENV = params.TEST_ENV
  env.FUNCTIONAL_TESTS_WORKERS = functionalWorkers
  env.PLAYWRIGHT_WORKERS = functionalWorkers
  env.API_PW_INCLUDE_TAGS = params.API_PW_INCLUDE_TAGS
  env.API_PW_EXCLUDED_TAGS_OVERRIDE = params.API_PW_EXCLUDED_TAGS_OVERRIDE
  env.E2E_PW_INCLUDE_TAGS = params.E2E_PW_INCLUDE_TAGS
  env.E2E_PW_EXCLUDED_TAGS_OVERRIDE = params.E2E_PW_EXCLUDED_TAGS_OVERRIDE
  env.INTEGRATION_PW_INCLUDE_TAGS = integrationIncludeTags
  env.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE = integrationExcludedTags
  env.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES = params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES
  env.GIT_BRANCH = env.BRANCH_NAME ?: (env.GIT_BRANCH ?: "local")
  enableSlackNotifications(channel)

  afterAlways('DependencyCheckNightly') {
    startCiLoadProfile()
    stage('Diag: Playwright execution environment') {
      recordPlaywrightContainerDiagnostics()
    }

    stage('Install Playwright Browsers') {
      recordPlaywrightLoadEvent('Playwright browser install', 'start')
      try {
        if (params.PLAYWRIGHT_USE_DOCKER) {
          echo '[playwright-container] Skipping browser install; official Playwright image already contains browsers.'
        } else {
          yarnBuilder.yarn('test:setup:playwright-install-chromium')
        }
      } finally {
        recordPlaywrightLoadEvent('Playwright browser install', 'finish')
      }
    }

    stage('Nightly tests') {
      recordPlaywrightLoadEvent('Nightly functional tests', 'start')
      try {
        def testStages = [
        'API nightly': {
          def apiWorkers = capJenkinsPlaywrightWorkers(params.FUNCTIONAL_TESTS_WORKERS)
          def apiOdhinEnv = [
            "FUNCTIONAL_TESTS_WORKERS=${apiWorkers}",
            "PLAYWRIGHT_WORKERS=${apiWorkers}",
            "API_PW_INCLUDE_TAGS=${params.API_PW_INCLUDE_TAGS}",
            "API_PW_EXCLUDED_TAGS_OVERRIDE=${params.API_PW_EXCLUDED_TAGS_OVERRIDE}",
            "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-api/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/api_functional/odhin-report',
            "PW_LOAD_PROFILE_EVENTS_FILE=${ciLoadProfileEventsFile}"
          ]
          try {
            recordPlaywrightLoadEvent('API', 'start')
            runInPlaywrightContainer {
              withEnv(apiOdhinEnv) {
                runPlaywrightCommand('test:api:ci:raw')
              }
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            withEnv(apiOdhinEnv) {
              yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
            }
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/tests/api_functional/odhin-report",
              reportFiles          : 'playwright-odhin.html',
              reportName           : 'API nightly report (Odhín)'
            ])
            junit(testResults: "playwright-junit.xml", allowEmptyResults: true)
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/api_functional/**'
            publishPlaywrightLoadProfile(
              'functional-output/tests/api_functional/odhin-report/load-profile',
              "API Nightly System Load (${apiWorkers} workers)"
            )
            recordPlaywrightLoadEvent('API', 'finish')
          }
        },
        'UI nightly': {
          def uiOdhinEnv = [
            'FUNCTIONAL_TESTS_WORKERS=2',
            'PLAYWRIGHT_WORKERS=2',
            "E2E_PW_INCLUDE_TAGS=${params.E2E_PW_INCLUDE_TAGS}",
            "E2E_PW_EXCLUDED_TAGS_OVERRIDE=${params.E2E_PW_EXCLUDED_TAGS_OVERRIDE}",
            "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/playwright-e2e/odhin-report',
            'PW_ODHIN_SKIP_API_ENDPOINTS=true',
            'PW_UI_USERS=COURT_ADMIN',
            'PW_UI_STORAGE_STRICT=1',
            'PW_UI_STORAGE=1',
            'PW_UI_STORAGE_TTL_MIN=15',
            'PW_UI_LOGIN_TIMEOUT_MS=120000',
            'PW_UI_IDLE_TIMEOUT_MS=60000',
            'PW_UI_IDLE_QUIET_MS=400',
            'PW_UI_FAIL_ON_HTTP_ERRORS=0',
            'PW_UI_FAIL_ON_HTTP_4XX=0',
            'PLAYWRIGHT_SKIP_INSTALL=true',
            "PW_LOAD_PROFILE_EVENTS_FILE=${ciLoadProfileEventsFile}"
          ]
          try {
            recordPlaywrightLoadEvent('UI', 'start')
            if (!hasCourtAdminUiCredentials()) {
              echo '[playwright-ui] Skipping UI nightly tests: COURT_ADMIN_USERNAME/COURT_ADMIN_PASSWORD were not loaded from Key Vault.'
              withEnv(uiOdhinEnv) {
                yarnBuilder.yarn('node ./scripts/ensure-odhin-report.cjs')
              }
            } else {
              runInPlaywrightContainer {
                withEnv(uiOdhinEnv) {
                  runPlaywrightCommand('test:crossbrowser:raw')
                }
              }
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            withEnv(uiOdhinEnv) {
              yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
            }
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/tests/playwright-e2e/odhin-report",
              reportFiles          : 'playwright-odhin.html',
              reportName           : 'UI nightly report (Odhín)'
            ])
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-e2e/odhin-report/**'
            publishPlaywrightLoadProfile(
              'functional-output/tests/playwright-e2e/odhin-report/load-profile',
              'UI Nightly System Load (2 workers)'
            )
            recordPlaywrightLoadEvent('UI', 'finish')
          }
        }
        ]
        def parallelTestStages = [:]
        testStages.each { testName, testBody ->
          def branchName = testName
          def branchBody = testBody
          parallelTestStages[branchName] = {
            stage(branchName) {
              branchBody()
            }
          }
        }
        parallel parallelTestStages

        stage("Integration nightly ${integrationIncludeTags}") {
          def integrationOdhinEnv = [
            "FUNCTIONAL_TESTS_WORKERS=${integrationWorkers}",
            "PLAYWRIGHT_WORKERS=${integrationWorkers}",
            'PW_UI_WORKERS=2',
            "INTEGRATION_PW_INCLUDE_TAGS=${integrationIncludeTags}",
            "INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE=${integrationExcludedTags}",
            "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
            "PLAYWRIGHT_REPORT_FOLDER=${integrationReportDir}",
            "PW_ODHIN_TARGET=${integrationReportDir}",
            'PLAYWRIGHT_REPORTERS=ci-brief,odhin',
            'PW_ODHIN_SKIP_API_ENDPOINTS=true',
            'PW_UI_STORAGE=1',
            'PW_UI_STORAGE_STRICT=1',
            'PW_UI_STORAGE_TTL_MIN=15',
            'PW_UI_LOGIN_TIMEOUT_MS=120000',
            'PW_UI_IDLE_TIMEOUT_MS=60000',
            'PW_UI_IDLE_QUIET_MS=400',
            'PW_UI_FAIL_ON_HTTP_ERRORS=0',
            'PW_UI_FAIL_ON_HTTP_4XX=0',
            'PLAYWRIGHT_SKIP_INSTALL=true',
            "PW_LOAD_PROFILE_EVENTS_FILE=${ciLoadProfileEventsFile}"
          ]
          try {
            recordPlaywrightLoadEvent("Integration ${integrationIncludeTags}", 'start')
            runInPlaywrightContainer {
              withEnv(integrationOdhinEnv) {
                runPlaywrightCommand("test:integration:nightly:raw -- --workers=${integrationWorkers}")
              }
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : integrationReportDir,
              reportFiles          : 'playwright-odhin-integration-nightly.html',
              reportName           : "Integration nightly report (${integrationIncludeTags})"
            ])
            archiveArtifacts allowEmptyArchive: true, artifacts: "${integrationReportDir}/**"
            publishPlaywrightLoadProfile(
              "${integrationReportDir}/load-profile",
              "Integration Nightly System Load (${integrationIncludeTags}, ${integrationWorkers} workers)"
            )
            recordPlaywrightLoadEvent("Integration ${integrationIncludeTags}", 'finish')
          }
        }
      } finally {
        recordPlaywrightLoadEvent('Nightly functional tests', 'finish')
        publishCiLoadProfile('RPX E2E Nightly CI System Load')
      }
    }
  }
}
