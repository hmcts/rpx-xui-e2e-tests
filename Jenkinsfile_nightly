def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)
def testVaultName = "rpx-${params.TEST_ENV}"
def runtimeTestSecrets = secrets[testVaultName] ?: []

def withTestVaultSecrets = { Closure body ->
  if (runtimeTestSecrets.isEmpty()) {
    error("No runtime test secrets configured for vault ${testVaultName}. Check TEST_ENV and Jenkins secret map.")
  }
  withAzureKeyvault(
    azureKeyVaultSecrets: runtimeTestSecrets,
    keyVaultURLOverride: "https://${testVaultName}.vault.azure.net/",
    applicationIDOverride: env.AZURE_CLIENT_ID,
    applicationSecretOverride: env.AZURE_CLIENT_SECRET
  ) {
    body.call()
  }
}

def logCredentialPresence = {
  sh(
    label: 'Credential preflight',
    script: '''
      set +x
      present() { [ -n "${!1:-}" ] && echo yes || echo no; }
      echo "Credential preflight: SOLICITOR_USERNAME=$(present SOLICITOR_USERNAME) PRL_SOLICITOR_USERNAME=$(present PRL_SOLICITOR_USERNAME) CASEWORKER_R1_USERNAME=$(present CASEWORKER_R1_USERNAME) COURT_ADMIN_USERNAME=$(present COURT_ADMIN_USERNAME) TEST_EMAIL=$(present TEST_EMAIL)"
      echo "Credential preflight: SOLICITOR_PASSWORD=$(present SOLICITOR_PASSWORD) PRL_SOLICITOR_PASSWORD=$(present PRL_SOLICITOR_PASSWORD) CASEWORKER_R1_PASSWORD=$(present CASEWORKER_R1_PASSWORD) COURT_ADMIN_PASSWORD=$(present COURT_ADMIN_PASSWORD) TEST_PASSWORD=$(present TEST_PASSWORD)"
      echo "Credential preflight: FPL_GLOBAL_SEARCH_USERNAME=$(present FPL_GLOBAL_SEARCH_USERNAME) FPL_GLOBAL_SEARCH_PASSWORD=$(present FPL_GLOBAL_SEARCH_PASSWORD) SEARCH_EMPLOYMENT_CASE_USERNAME=$(present SEARCH_EMPLOYMENT_CASE_USERNAME) SEARCH_EMPLOYMENT_CASE_PASSWORD=$(present SEARCH_EMPLOYMENT_CASE_PASSWORD) USER_WITH_FLAGS_USERNAME=$(present USER_WITH_FLAGS_USERNAME) USER_WITH_FLAGS_PASSWORD=$(present USER_WITH_FLAGS_PASSWORD)"
    '''
  )
}

def publishOdhinHtmlIfPresent = { String reportDir, String reportFile, String reportName, List<String> fallbackReportFiles = [] ->
  if (fileExists(reportDir)) {
    def candidateReportFiles = ([reportFile] + fallbackReportFiles).findAll { it?.trim() }
    def selectedReportFile = candidateReportFiles.find { candidate ->
      fileExists("${reportDir}/${candidate}")
    } ?: reportFile
    if (selectedReportFile != reportFile) {
      echo "Publishing fallback Odhin file for ${reportName}: ${selectedReportFile}"
    } else if (!fileExists("${reportDir}/${reportFile}")) {
      echo "Odhin file not found for ${reportName}: expected ${reportFile} under ${reportDir}. Trying publishHTML with allowMissing."
    }
    publishHTML([
      allowMissing         : true,
      alwaysLinkToLastBuild: true,
      keepAll              : true,
      reportDir            : reportDir,
      reportFiles          : selectedReportFile,
      reportName           : reportName
    ])
  } else {
    echo "Skipping Odhin HTML publish for ${reportName}: missing ${reportDir}"
  }
}

def publishJunitIfPresent = { String reportFile ->
  if (fileExists(reportFile)) {
    junit(testResults: reportFile, allowEmptyResults: true)
  } else {
    echo "Skipping JUnit publish: missing ${reportFile}"
  }
}

def resolvePositiveInteger = { String rawValue, int fallbackValue ->
  try {
    def parsed = rawValue?.trim()?.toInteger()
    return (parsed && parsed > 0) ? parsed : fallbackValue
  } catch (ignored) {
    return fallbackValue
  }
}

withNightlyPipeline(type, product, component, 400) {
  loadVaultSecrets(secrets)
  env.TEST_URL = params.TEST_URL
  env.TEST_ENV = params.TEST_ENV
  env.FUNCTIONAL_TESTS_WORKERS = params.FUNCTIONAL_TESTS_WORKERS
  def totalWorkerBudget = resolvePositiveInteger(params.FUNCTIONAL_TESTS_WORKERS, 8)
  def apiWorkers = Math.min(3, Math.max(1, (int) Math.floor(totalWorkerBudget / 4.0d)))
  def integrationWorkers = Math.min(3, Math.max(1, (int) Math.floor(totalWorkerBudget / 4.0d)))
  def uiWorkers = Math.min(4, Math.max(1, totalWorkerBudget - apiWorkers - integrationWorkers))
  env.PLAYWRIGHT_WORKERS = uiWorkers.toString()
  echo "Playwright worker budget: total=${totalWorkerBudget}, api=${apiWorkers}, ui=${uiWorkers}, integration=${integrationWorkers}"
  env.GIT_BRANCH = env.BRANCH_NAME ?: (env.GIT_BRANCH ?: "local")
  enableSlackNotifications(channel)

  afterAlways('DependencyCheckNightly') {
    stage('Lint') {
      yarnBuilder.yarn('lint:ci')
    }

    stage('Install Playwright Browsers') {
      yarnBuilder.yarn('pwinstall')
    }

    stage('Nightly tests') {
      parallel(
        'API nightly': {
          def apiOdhinEnv = [
            "PLAYWRIGHT_WORKERS=${apiWorkers}",
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-api/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/api_functional/odhin-report',
            'PW_ODHIN_INDEX=playwright-odhin-api.html'
          ]
          try {
            def tagArg = params.tag ? "--grep \"${params.tag}\"" : ""
            withTestVaultSecrets {
              logCredentialPresence()
              withEnv(apiOdhinEnv) {
                yarnBuilder.yarn("test:api:pw:coverage ${tagArg}")
              }
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            publishOdhinHtmlIfPresent(
              'functional-output/tests/api_functional/odhin-report',
              'playwright-odhin-api.html',
              'Odhín nightly report-api'
            )
            publishJunitIfPresent('playwright-junit.xml')
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/api_functional/**'
          }
        },
        'UI nightly': {
          def uiOdhinEnv = [
            "PLAYWRIGHT_WORKERS=${uiWorkers}",
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/playwright-e2e/odhin-report',
            'PW_ODHIN_INDEX=playwright-odhin-e2e.html',
            'PW_ODHIN_SKIP_API_ENDPOINTS=true',
            'PLAYWRIGHT_VIDEO=off',
            'PW_UI_USERS=COURT_ADMIN',
            'PW_UI_STORAGE_STRICT=1',
            'PW_UI_STORAGE=1',
            'PW_UI_STORAGE_TTL_MIN=15',
            'PW_UI_LOGIN_TIMEOUT_MS=120000',
            'PW_UI_IDLE_TIMEOUT_MS=60000',
            'PW_UI_IDLE_QUIET_MS=400',
            'PW_UI_FAIL_ON_HTTP_ERRORS=0',
            'PW_UI_FAIL_ON_HTTP_4XX=0'
          ]
          def uiOdhinCopyEnv = [
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e-all/odhin-report',
            'PW_ODHIN_OUTPUT=functional-output/tests/playwright-e2e-all/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/playwright-e2e/odhin-report'
          ]
          try {
            def tagArg = params.tag ? "--grep \"${params.tag}\"" : ""
            withTestVaultSecrets {
              logCredentialPresence()
              withEnv(uiOdhinEnv) {
                yarnBuilder.yarn("test:playwrightE2E ${tagArg}")
              }
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
              withEnv(uiOdhinCopyEnv) {
                yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
              }
            }
            publishOdhinHtmlIfPresent(
              'functional-output/tests/playwright-e2e/odhin-report',
              'playwright-odhin-e2e.html',
              'Odhín nightly report-e2e',
              ['playwright-odhin-e2e-all.html']
            )
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-e2e/odhin-report/**,functional-output/tests/playwright-e2e-all/odhin-report/**'
          }
        },
        'Integration nightly': {
          def integrationOdhinEnv = [
            "PLAYWRIGHT_WORKERS=${integrationWorkers}",
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-integration/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/playwright-integration/odhin-report',
            'PW_ODHIN_INDEX=playwright-odhin-integration.html',
            'PW_ODHIN_SKIP_API_ENDPOINTS=true',
            'PLAYWRIGHT_VIDEO=off',
            'PW_UI_FAIL_ON_HTTP_ERRORS=0',
            'PW_UI_FAIL_ON_HTTP_4XX=0'
          ]
          try {
            def tagArg = params.tag ? "--grep \"${params.tag}\"" : ""
            withTestVaultSecrets {
              logCredentialPresence()
              withEnv(integrationOdhinEnv) {
                yarnBuilder.yarn("test:playwright:integration ${tagArg}")
              }
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            withEnv(integrationOdhinEnv) {
              yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
            }
            publishOdhinHtmlIfPresent(
              'functional-output/tests/playwright-integration/odhin-report',
              'playwright-odhin-integration.html',
              'Odhín nightly report-integration'
            )
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-integration/odhin-report/**'
          }
        }
      )
    }
  }
}
