def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)
def playwrightLoadProfileReportFile = 'load-profile.html'

def publishPlaywrightLoadProfile = { String reportDir, String reportName ->
  def safeReportName = reportName.replaceAll(/[^A-Za-z0-9._-]/, '-')
  def slimReportDir = "functional-output/tests/playwright-published-reports/load-profile/${safeReportName}"
  steps.sh """
    set +e
    node scripts/ensure-load-profile-report.cjs \\
      --report-dir '${reportDir}' \\
      --report-file '${playwrightLoadProfileReportFile}' \\
      --report-name '${reportName}'
  """
  steps.sh """
    set +e
    mkdir -p '${slimReportDir}'
    if [ -f '${reportDir}/${playwrightLoadProfileReportFile}' ]; then
      cp '${reportDir}/${playwrightLoadProfileReportFile}' '${slimReportDir}/${playwrightLoadProfileReportFile}'
    fi
  """
  archiveArtifacts allowEmptyArchive: true, artifacts: "${slimReportDir}/${playwrightLoadProfileReportFile}"
  publishHTML([
    allowMissing         : true,
    alwaysLinkToLastBuild: true,
    keepAll              : true,
    reportDir            : "${slimReportDir}/",
    reportFiles          : playwrightLoadProfileReportFile,
    reportName           : reportName
  ])
}

def resolveIntegrationProfileRuns = { String configuredRuns, String workersOverride, String shardOverride ->
  def requestedWorkers = workersOverride?.trim()
  if (requestedWorkers) {
    def requestedShard = shardOverride?.trim()
    return ["workers=${requestedWorkers}${requestedShard ? " shard=${requestedShard}" : ''}"]
  }
  def configured = configuredRuns?.trim()
  if (!configured) {
    configured = 'workers=4'
  }
  return configured
    .split(/[\r\n;]+/)
    .collect { it.trim() }
    .findAll { it }
}

def integrationProfileRunConfig = { String spec ->
  def workers = params.FUNCTIONAL_TESTS_WORKERS ?: '4'
  def shard = ''
  spec.split(/\s+/).each { token ->
    if (token.startsWith('workers=')) {
      workers = token.replaceFirst('workers=', '')
    }
    if (token.startsWith('shard=')) {
      shard = token.replaceFirst('shard=', '')
    }
  }
  def safeName = "workers-${workers}${shard ? "-shard-${shard}" : ''}".replaceAll(/[^A-Za-z0-9._-]/, '-')
  return [
    workers: workers,
    shardArg: shard ? "--shard=${shard}" : '',
    reportDir: "functional-output/tests/playwright-integration-nightly/odhin-report/nightly-${safeName}",
    displayName: "${workers} workers${shard ? ", shard ${shard}" : ''}"
  ]
}

withNightlyPipeline(type, product, component, 400) {
  loadVaultSecrets(secrets)
  env.TEST_URL = params.TEST_URL
  env.TEST_ENV = params.TEST_ENV
  env.FUNCTIONAL_TESTS_WORKERS = params.FUNCTIONAL_TESTS_WORKERS
  env.PLAYWRIGHT_WORKERS = params.FUNCTIONAL_TESTS_WORKERS
  env.API_PW_INCLUDE_TAGS = params.API_PW_INCLUDE_TAGS
  env.API_PW_EXCLUDED_TAGS_OVERRIDE = params.API_PW_EXCLUDED_TAGS_OVERRIDE
  env.E2E_PW_INCLUDE_TAGS = params.E2E_PW_INCLUDE_TAGS
  env.E2E_PW_EXCLUDED_TAGS_OVERRIDE = params.E2E_PW_EXCLUDED_TAGS_OVERRIDE
  env.INTEGRATION_PW_INCLUDE_TAGS = params.INTEGRATION_PW_INCLUDE_TAGS
  env.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE = params.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE
  env.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES = params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES
  env.GIT_BRANCH = env.BRANCH_NAME ?: (env.GIT_BRANCH ?: "local")
  enableSlackNotifications(channel)

  afterAlways('DependencyCheckNightly') {
    stage('Install Playwright Browsers') {
      yarnBuilder.yarn('pwinstall')
    }

    stage('Nightly tests') {
      parallel(
        'API nightly': {
          def apiWorkers = params.FUNCTIONAL_TESTS_WORKERS ?: '4'
          def apiOdhinEnv = [
            "FUNCTIONAL_TESTS_WORKERS=${apiWorkers}",
            "PLAYWRIGHT_WORKERS=${apiWorkers}",
            "API_PW_INCLUDE_TAGS=${params.API_PW_INCLUDE_TAGS}",
            "API_PW_EXCLUDED_TAGS_OVERRIDE=${params.API_PW_EXCLUDED_TAGS_OVERRIDE}",
            "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-api/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/api_functional/odhin-report'
          ]
          try {
            withEnv(apiOdhinEnv) {
              yarnBuilder.yarn('test:api')
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            withEnv(apiOdhinEnv) {
              yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
            }
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/tests/api_functional/odhin-report",
              reportFiles          : 'playwright-odhin.html',
              reportName           : 'API nightly report (Odhín)'
            ])
            junit(testResults: "playwright-junit.xml", allowEmptyResults: true)
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/api_functional/**'
            publishPlaywrightLoadProfile(
              'functional-output/tests/api_functional/odhin-report/load-profile',
              "API Nightly System Load (${apiWorkers} workers)"
            )
          }
        },
        'Integration nightly': {
          resolveIntegrationProfileRuns(
            params.INTEGRATION_PW_PROFILE_RUNS ?: '',
            params.INTEGRATION_PW_WORKERS ?: '',
            params.INTEGRATION_PW_SHARD ?: ''
          ).each { spec ->
            def runConfig = integrationProfileRunConfig(spec)
            def integrationOdhinEnv = [
              "FUNCTIONAL_TESTS_WORKERS=${runConfig.workers}",
              "PLAYWRIGHT_WORKERS=${runConfig.workers}",
              "INTEGRATION_PW_INCLUDE_TAGS=${params.INTEGRATION_PW_INCLUDE_TAGS}",
              "INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE=${params.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE}",
              "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
              'PW_UI_STORAGE=1',
              'PW_ODHIN_INDEX=playwright-odhin-integration-nightly.html',
              'PLAYWRIGHT_REPORT_INDEX_FILENAME=playwright-odhin-integration-nightly.html',
              "PLAYWRIGHT_REPORT_FOLDER=${runConfig.reportDir}",
              "PW_LOAD_PROFILE_OUTPUT=${runConfig.reportDir}/load-profile",
              "PW_LOAD_PROFILE_LABEL=Integration nightly ${runConfig.displayName}"
            ]
            try {
              withEnv(integrationOdhinEnv) {
                yarnBuilder.yarn("test:integration:nightly${runConfig.shardArg ? " -- ${runConfig.shardArg}" : ""}")
              }
            } catch (Error) {
              unstable(message: "${STAGE_NAME} ${runConfig.displayName} is unstable: " + Error.toString())
            } finally {
              withEnv(integrationOdhinEnv) {
                yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
              }
              publishHTML([
                allowMissing         : true,
                alwaysLinkToLastBuild: true,
                keepAll              : true,
                reportDir            : "${runConfig.reportDir}",
                reportFiles          : 'playwright-odhin-integration-nightly.html',
                reportName           : "Integration nightly report (Odhín, ${runConfig.displayName})"
              ])
              archiveArtifacts allowEmptyArchive: true, artifacts: "${runConfig.reportDir}/**"
              publishPlaywrightLoadProfile(
                "${runConfig.reportDir}/load-profile",
                "Integration Nightly System Load (${runConfig.displayName})"
              )
            }
          }
        },
        'UI nightly': {
          def uiOdhinEnv = [
            'FUNCTIONAL_TESTS_WORKERS=2',
            'PLAYWRIGHT_WORKERS=2',
            "E2E_PW_INCLUDE_TAGS=${params.E2E_PW_INCLUDE_TAGS}",
            "E2E_PW_EXCLUDED_TAGS_OVERRIDE=${params.E2E_PW_EXCLUDED_TAGS_OVERRIDE}",
            "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES}",
            'PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e/odhin-report',
            'PW_ODHIN_TARGET=functional-output/tests/playwright-e2e/odhin-report',
            'PW_ODHIN_SKIP_API_ENDPOINTS=true',
            'PW_UI_USERS=COURT_ADMIN',
            'PW_UI_STORAGE_STRICT=1',
            'PW_UI_STORAGE=1',
            'PW_UI_STORAGE_TTL_MIN=15',
            'PW_UI_LOGIN_TIMEOUT_MS=120000',
            'PW_UI_IDLE_TIMEOUT_MS=60000',
            'PW_UI_IDLE_QUIET_MS=400',
            'PW_UI_FAIL_ON_HTTP_ERRORS=0',
            'PW_UI_FAIL_ON_HTTP_4XX=0'
          ]
          try {
            withEnv(uiOdhinEnv) {
              yarnBuilder.yarn('test:crossbrowser')
            }
          } catch (Error) {
            unstable(message: "${STAGE_NAME} is unstable: " + Error.toString())
          } finally {
            withEnv(uiOdhinEnv) {
              yarnBuilder.yarn('node ./scripts/copy-odhin-report.cjs')
            }
            publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/tests/playwright-e2e/odhin-report",
              reportFiles          : 'playwright-odhin.html',
              reportName           : 'UI nightly report (Odhín)'
            ])
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-e2e/odhin-report/**'
            publishPlaywrightLoadProfile(
              'functional-output/tests/playwright-e2e/odhin-report/load-profile',
              'UI Nightly System Load (2 workers)'
            )
          }
        }
      )
    }
  }
