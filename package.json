{
  "name": "rpx-xui-e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.1"
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "pwinstall": "yarn playwright install --with-deps",
    "setup": "yarn install --immutable && yarn get-secrets rpx-aat && yarn pwinstall && yarn playwright install webkit && yarn playwright install firefox",
    "get-secrets": "node ./node_modules/@hmcts/playwright-common/dist/scripts/get-secrets.js",
    "prepare": "husky install",
    "lint": "yarn tsc -p tsconfig.json && yarn eslint .",
    "outdated": "NPM_CONFIG_CACHE=.npm-cache npm outdated --depth=0",
    "lint:prettier": "prettier -c .",
    "lint:prettier:fix": "prettier -w .",
    "ui:session": "node ./scripts/record-ui-session.mjs",
    "test:api": "PLAYWRIGHT_REPORTERS=list,odhin yarn playwright test --project=api",
    "test:api:pw": "yarn playwright test --project=api",
    "test:api:ci": "PLAYWRIGHT_REPORTERS=list,odhin,junit yarn playwright test --project=api",
    "test:api:html": "PLAYWRIGHT_REPORTERS=list,html yarn playwright test --project=api",
    "test:api:coverage": "rm -rf coverage && (PW_ODHIN_LINK_COVERAGE=true PLAYWRIGHT_REPORTERS=list,odhin,junit yarn c8 --reporter=lcov --reporter=json-summary --reporter=text --reporter=text-summary --reporter=html --report-dir ./coverage playwright test --project=api || true) && (node ./scripts/reportCoverage.cjs || true) && (PW_ODHIN_LINK_COVERAGE=true node ./scripts/copy-odhin-report.cjs || true)",
    "test:playwrightE2E": "node ./scripts/run-playwright-e2e.cjs",
    "test:playwright:integration": "node ./scripts/run-playwright-integration.cjs",
    "test:ui": "node ./scripts/run-playwright-e2e.cjs",
    "test:ui:smoke": "node ./scripts/run-playwright-e2e.cjs -- --grep @smoke",
    "test:ui:divorce:dynamic-flags": "yarn playwright test src/tests/e2e/caseFlags/caseFlags.dynamic-user.spec.ts --project=ui --workers=1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@faker-js/faker": "^10.3.0",
    "@hmcts/playwright-common": "^1.1.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "c8": "^11.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.8.0",
    "husky": "^9.1.7",
    "odhin-reports-playwright": "patch:odhin-reports-playwright@npm%3A1.1.8#~/.yarn/patches/odhin-reports-playwright-npm-1.1.8-a445ed88b7.patch",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
