{
  "name": "rpx-xui-e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.1"
  },
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "pwinstall": "yarn playwright install --with-deps",
    "setup": "yarn install --immutable && yarn env:populate:playwright:aat && yarn pwinstall && yarn playwright install webkit && yarn playwright install firefox",
    "get-secrets": "node ./node_modules/@hmcts/playwright-common/dist/scripts/get-secrets.js",
    "env:populate": "bash ./scripts/populate-env-from-keyvault.sh",
    "env:populate:aat": "bash ./scripts/populate-env-from-keyvault.sh aat",
    "env:populate:demo": "bash ./scripts/populate-env-from-keyvault.sh demo",
    "env:populate:playwright": "bash ./scripts/populate-playwright-env-from-keyvault.sh",
    "env:populate:playwright:aat": "bash ./scripts/populate-playwright-env-from-keyvault.sh aat",
    "env:populate:playwright:demo": "bash ./scripts/populate-playwright-env-from-keyvault.sh demo",
    "lint": "./node_modules/.bin/tsc -p tsconfig.json && ./node_modules/.bin/eslint .",
    "ui:session": "node ./scripts/record-ui-session.mjs",
    "supertest:local:shell": "node ./scripts/local-exui-static-proxy.mjs",
    "supertest:manifest": "node ./scripts/check-exui-supertest-manifest.mjs",
    "supertest:ci": "node ./scripts/run-supertest-local-poc.mjs --ci --odhin",
    "supertest:local:prove": "node ./scripts/run-supertest-local-poc.mjs",
    "supertest:local:odhin": "node ./scripts/run-supertest-local-poc.mjs --odhin",
    "supertest:local:validate": "node ./scripts/run-supertest-local-poc.mjs --manifest --lint",
    "test:api": "PLAYWRIGHT_REPORTERS=list,odhin yarn playwright test --project=api",
    "test:api:ci": "PLAYWRIGHT_REPORTERS=list,odhin,junit yarn playwright test --project=api",
    "test:api:html": "PLAYWRIGHT_REPORTERS=list,html yarn playwright test --project=api",
    "test:api:coverage": "rm -rf coverage && (PW_ODHIN_LINK_COVERAGE=true PLAYWRIGHT_REPORTERS=list,odhin yarn c8 --reporter=lcov --reporter=json-summary --reporter=text --reporter=text-summary --reporter=html --report-dir ./coverage playwright test --project=api || true) && (node ./scripts/reportCoverage.cjs || true) && (PW_ODHIN_LINK_COVERAGE=true node ./scripts/copy-odhin-report.cjs || true)",
    "test:integration": "PW_UI_STORAGE=1 PW_ODHIN_INDEX=playwright-odhin-integration.html PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-integration/odhin-report PLAYWRIGHT_REPORTERS=list,odhin yarn playwright test --project=integration",
    "test:integration:nightly": "PW_UI_STORAGE=1 PW_ODHIN_INDEX=playwright-odhin-integration-nightly.html PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-integration-nightly/odhin-report PLAYWRIGHT_REPORTERS=list,odhin yarn playwright test --project=integration-nightly",
    "test:playwright:integration": "yarn playwright install && yarn test:integration",
    "test:ui": "PW_UI_STORAGE=1 PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e/odhin-report PLAYWRIGHT_REPORTERS=list,odhin yarn playwright test --project=ui",
    "test:ui:smoke": "PW_UI_STORAGE=1 PLAYWRIGHT_REPORT_FOLDER=functional-output/tests/playwright-e2e/odhin-report PLAYWRIGHT_REPORTERS=list,odhin yarn playwright test --project=ui --grep @smoke"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@faker-js/faker": "^10.0.0",
    "@hmcts/playwright-common": "^1.1.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.9.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "c8": "^11.0.0",
    "dotenv": "^17.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-playwright": "^2.1.0",
    "node-html-parser": "^7.0.0",
    "odhin-reports-playwright": "^1.1.8",
    "prettier": "^3.3.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.1",
    "uuid": "^14.0.0",
    "zod": "^4.0.0"
  }
}
